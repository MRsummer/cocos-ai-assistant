{
    "package_version": 2,
    "name": "cocos-ai-assistant",
    "version": "1.0.0",
    "author": "MRsummer",
    "editor": ">=3.8.6",
    "scripts": {
        "preinstall": "node ./scripts/preinstall.js",
        "build": "tsc",
        "watch": "tsc -w"
    },
    "description": "i18n:cocos-ai-assistant.description",
    "main": "./dist/main.js",
    "dependencies": {
        "fs-extra": "^11.3.0",
        "uuid": "^9.0.1",
        "vue": "^3.1.4"
    },
    "devDependencies": {
        "@cocos/creator-types": "^3.8.6",
        "@types/fs-extra": "^9.0.5",
        "@types/node": "^18.17.1",
        "@types/uuid": "^9.0.8",
        "typescript": "^5.8.2"
    },
    "panels": {
        "default": {
            "title": "i18n:cocos-ai-assistant.panel_ai_chat",
            "type": "dockable",
            "main": "dist/panels/default",
            "icon": "./static/icon.png",
            "size": {
                "min-width": 420,
                "min-height": 500,
                "width": 520,
                "height": 700
            }
        },
        "asset-studio": {
            "title": "i18n:cocos-ai-assistant.panel_asset_studio",
            "type": "dockable",
            "main": "dist/panels/asset-studio",
            "icon": "./static/icon.png",
            "size": {
                "min-width": 450,
                "min-height": 400,
                "width": 600,
                "height": 650
            }
        },
        "templates": {
            "title": "i18n:cocos-ai-assistant.panel_templates",
            "type": "dockable",
            "main": "dist/panels/templates",
            "icon": "./static/icon.png",
            "size": {
                "min-width": 400,
                "min-height": 400,
                "width": 600,
                "height": 600
            }
        }
    },
    "contributions": {
        "menu": [
            {
                "path": "i18n:menu.extension/Cocos AI Assistant",
                "label": "i18n:cocos-ai-assistant.menu_ai_chat",
                "message": "open-panel"
            },
            {
                "path": "i18n:menu.extension/Cocos AI Assistant",
                "label": "i18n:cocos-ai-assistant.menu_asset_studio",
                "message": "open-asset-studio"
            },
            {
                "path": "i18n:menu.extension/Cocos AI Assistant",
                "label": "i18n:cocos-ai-assistant.menu_templates",
                "message": "open-templates"
            }
        ],
        "messages": {
            "open-panel": {
                "methods": ["openPanel"]
            },
            "open-asset-studio": {
                "methods": ["openAssetStudio"]
            },
            "open-templates": {
                "methods": ["openTemplates"]
            },
            "start-server": {
                "methods": ["startServer"]
            },
            "stop-server": {
                "methods": ["stopServer"]
            },
            "get-server-status": {
                "methods": ["getServerStatus"]
            },
            "update-settings": {
                "methods": ["updateSettings"]
            },
            "getToolsList": {
                "methods": ["getToolsList"]
            },
            "get-server-settings": {
                "methods": ["getServerSettings"]
            },
            "ai-chat": {
                "methods": ["aiChat"]
            },
            "ai-chat-stop": {
                "methods": ["aiChatStop"]
            },
            "ai-chat-history": {
                "methods": ["aiChatHistory"]
            },
            "ai-chat-clear": {
                "methods": ["aiChatClear"]
            },
            "ai-generate-image": {
                "methods": ["aiGenerateImage"]
            },
            "get-game-templates": {
                "methods": ["getGameTemplates"]
            },
            "create-game-from-template": {
                "methods": ["createGameFromTemplate"]
            },
            "getToolManagerState": {
                "methods": ["getToolManagerState"]
            },
            "getEnabledTools": {
                "methods": ["getEnabledTools"]
            }
        },
        "scene": {
            "script": "./dist/scene.js",
            "methods": [
                "createNewScene",
                "addComponentToNode",
                "removeComponentFromNode",
                "getNodeInfo",
                "getAllNodes",
                "findNodeByName",
                "setNodeProperty",
                "setComponentProperty",
                "getCurrentSceneInfo",
                "getSceneHierarchy",
                "createPrefabFromNode"
            ]
        }
    }
}
